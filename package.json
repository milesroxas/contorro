{
  "name": "contorro",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -b",
    "build:cms": "pnpm --filter @repo/cms build",
    "build:gw": "pnpm --filter @repo/gateway build",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm --filter @repo/cms exec payload migrate && pnpm --filter @repo/cms exec payload migrate && pnpm test",
    "db:up": "docker compose up db -d",
    "db:reset": "docker compose down -v && docker compose up db -d",
    "dev": "pnpm --filter @repo/presentation-studio dev & pnpm --filter @repo/presentation-admin-extensions dev & pnpm --filter @repo/infrastructure-payload-config dev & pnpm --filter @repo/cms dev & pnpm --filter @repo/gateway dev",
    "dev:cms": "pnpm --filter @repo/cms dev",
    "dev:gw": "pnpm --filter @repo/gateway dev",
    "dev:studio": "pnpm --filter @repo/presentation-studio dev",
    "e2e": "pnpm --filter @repo/cms run test:e2e",
    "e2e:ui": "pnpm --filter @repo/cms run test:e2e:ui",
    "fmt": "pnpm run format",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "migrate": "node ./scripts/migrate.mjs",
    "migrate:create": "pnpm --filter @repo/cms exec payload migrate:create",
    "payload": "pnpm --filter @repo/cms run payload --",
    "seed": "pnpm --filter @repo/cms exec payload run src/seeds/index.ts",
    "seed:design-system": "node ./scripts/seed-design-system.mjs",
    "tc": "pnpm run typecheck",
    "test": "pnpm --filter @repo/cms run test:int",
    "test:all": "pnpm run test:int && pnpm run test:gw",
    "test:cov": "pnpm --filter @repo/cms run test:coverage",
    "test:e2e": "pnpm run e2e",
    "test:gw": "pnpm --filter @repo/gateway test",
    "test:int": "pnpm --filter @repo/cms run test:int",
    "test:watch": "pnpm --filter @repo/cms run test:watch",
    "typecheck": "tsc -b && pnpm --filter @repo/cms exec tsc --noEmit",
    "vercel:pull:preview": "vercel env pull apps/cms/.env.vercel.preview.local --environment preview --yes",
    "vercel:pull:prod": "vercel env pull apps/cms/.env.vercel.production.local --environment production --yes"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "dotenv-cli": "^11.0.0",
    "typescript": "^6.0.2",
    "vercel": "^51.5.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "bufferutil",
      "utf-8-validate",
      "protobufjs"
    ],
    "overrides": {
      "payload": "3.83.0",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    }
  }
}
