    "@repo/application-publish-flow": "workspace:*",
    "@repo/config-env": "workspace:*",
    "@repo/contracts-zod": "workspace:*",
    "@repo/infrastructure-event-bus": "workspace:*",
    "@repo/infrastructure-payload-config": "workspace:*",
    "@repo/infrastructure-persistence": "workspace:*",
    "@repo/kernel": "workspace:*",
    "dotenv": "16.4.7",
    "hono": "^4.6.0",
    "payload": "3.82.1",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
