{
  "name": "@repo/cms",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --dir ../.. --filter @repo/gateway build",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "predev": "pnpm --dir ../.. --filter @repo/gateway build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "pnpm --dir ../.. run lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/email-resend": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/storage-vercel-blob": "3.83.0",
    "@payloadcms/translations": "3.83.0",
    "@payloadcms/ui": "3.83.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@repo/application-design-system": "workspace:*",
    "@repo/application-publish-flow": "workspace:*",
    "@repo/application-studio": "workspace:*",
    "@repo/config-env": "workspace:*",
    "@repo/config-tailwind": "workspace:*",
    "@repo/contracts-json-schema": "workspace:*",
    "@repo/contracts-zod": "workspace:*",
    "@repo/domains-composition": "workspace:*",
    "@repo/gateway": "workspace:*",
    "@repo/infrastructure-blob-storage": "workspace:*",
    "@repo/infrastructure-event-bus": "workspace:*",
    "@repo/infrastructure-payload-config": "workspace:*",
    "@repo/infrastructure-telemetry": "workspace:*",
    "@repo/kernel": "workspace:*",
    "@repo/presentation-admin-extensions": "workspace:*",
    "@repo/presentation-preview-ui": "workspace:*",
    "@repo/presentation-shared": "workspace:*",
    "@repo/presentation-studio": "workspace:*",
    "@repo/runtime-code-components": "workspace:*",
    "@repo/runtime-primitives": "workspace:*",
    "@repo/runtime-renderer": "workspace:*",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.2",
    "graphql": "^16.13.2",
    "next": "16.2.4",
    "payload": "3.83.0",
    "postcss": "^8.5.10",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.3.0",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.0.2",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
