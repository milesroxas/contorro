# Copy to `.env` for local dev. Postgres: `pnpm db:up` from repo root (default port 54332).
POSTGRES_URL=postgresql://app:app@127.0.0.1:54332/builder
# Optional — direct URL for migrate-only scripts (Neon); omit locally.
# POSTGRES_URL_DIRECT=

PAYLOAD_SECRET=replace-with-at-least-32-characters-long-secret
SITE_URL=http://localhost:3000
PREVIEW_SECRET=replace-with-at-least-32-characters-preview-secret
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token-or-placeholder-for-local
