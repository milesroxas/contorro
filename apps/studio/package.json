{
  "name": "@repo/studio",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "pnpm --dir ../.. run lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-vercel-postgres": "3.82.1",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/ui": "3.82.1",
    "@repo/application-builder": "workspace:*",
    "@repo/application-page-composer": "workspace:*",
    "@repo/application-publish-flow": "workspace:*",
    "@repo/config-env": "workspace:*",
    "@repo/config-tailwind": "workspace:*",
    "@repo/contracts-json-schema": "workspace:*",
    "@repo/contracts-zod": "workspace:*",
    "@repo/infrastructure-blob-storage": "workspace:*",
    "@repo/infrastructure-event-bus": "workspace:*",
    "@repo/infrastructure-payload-config": "workspace:*",
    "@repo/infrastructure-persistence": "workspace:*",
    "@repo/infrastructure-telemetry": "workspace:*",
    "@repo/kernel": "workspace:*",
    "@repo/presentation-admin-extensions": "workspace:*",
    "@repo/presentation-builder-ui": "workspace:*",
    "@repo/presentation-composer-ui": "workspace:*",
    "@repo/presentation-preview-ui": "workspace:*",
    "@repo/presentation-shared": "workspace:*",
    "@repo/runtime-code-components": "workspace:*",
    "@repo/runtime-primitives": "workspace:*",
    "@repo/runtime-renderer": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.2",
    "payload": "3.82.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "jsdom": "28.0.0",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
