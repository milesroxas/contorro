{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.next/**",
      "**/pnpm-lock.yaml",
      "**/.git/**",
      "**/coverage/**",
      "**/playwright-report/**",
      "**/test-results/**",
      "apps/cms/src/payload-types.ts",
      "apps/cms/src/payload-generated-schema.ts",
      "apps/cms/src/app/(payload)/admin/importMap.js"
    ]
  },
  "organizeImports": { "enabled": true },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 15
          }
        }
      }
    }
  }
}
