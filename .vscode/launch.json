{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug CMS app (@repo/cms)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/apps/cms/node_modules/next/dist/bin/next",
      "runtimeArgs": ["--inspect"],
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "action": "debugWithChrome",
        "killOnServerStop": true,
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}/apps/cms"
      },
      "cwd": "${workspaceFolder}/apps/cms"
    }
  ]
}
