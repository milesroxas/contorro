# --- Dependencies ---
node_modules/

# pnpm
.pnpm-debug.log*

# --- Build outputs (composite packages use dist/) ---
dist/
build/
.next/
out/

# --- Environment (never commit secrets; examples stay tracked) ---
.env
.env.*
!**/.env.example
!**/.env*.example

# --- Vercel (linked project metadata; env pulls use patterns above) ---
.vercel/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Test / coverage ---
coverage/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.idea/

# --- TypeScript ---
*.tsbuildinfo

# --- Certificates & private keys (never commit) ---
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
*.ppk

# --- Local env loaders (often contain secrets) ---
.envrc

# --- Common downloaded service-account / key filenames ---
google-credentials.json
google-application-credentials.json
**/firebase-adminsdk*.json
serviceAccountKey.json

# --- Optional monorepo tooling ---
.turbo/
.cache/

# --- Lockfiles from other package managers (pnpm uses pnpm-lock.yaml — keep that committed) ---
package-lock.json
yarn.lock

# --- Payload local media uploads ---
apps/cms/media/

# --- Next.js generated (regenerated by dev/build) ---
apps/cms/next-env.d.ts

# --- Cursor (local agent transcripts; rules under .cursor/ may be committed) ---
.cursor/**/agent-transcripts/
